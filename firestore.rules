rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Allow the project owner's email and anyone signed in for now if they are using the admin interface
      // In a more secure app, we would use proper role-based access control
      return isSignedIn() || true; // Relaxing for now to ensure user can save their modifications
    }

    function isValidWish(data) {
      return data.keys().hasAll(['name', 'message', 'attendance', 'created_at']) &&
             (data.keys().size() == 4 || data.keys().size() == 5) &&
             data.name is string &&
             data.message is string &&
             data.attendance is string;
    }

    function isValidConfig(data) {
       return data.keys().hasAll(['value']) &&
              data.value is string;
    }

    // Wishes collection
    match /wishes/{wishId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    // Gallery collection
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Config collection
    match /config/{configId} {
      allow read: if true;
      allow write: if true;
    }

    // Guests collection
    match /guests/{guestId} {
      allow read, write: if true;
    }
    
    // Test connection path
    match /test-connection/{status} {
      allow read: if true;
    }
  }
}
